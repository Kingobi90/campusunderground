<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pomodoro Timer - Compact</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#ffff00',
                        dark: {
                            100: '#2a2a2a',
                            200: '#1a1a1a',
                            300: '#111111',
                            400: '#0a0a0a',
                        },
                    },
                    animation: {
                        'spin-slow': 'spin 3s linear infinite',
                        'pulse-slow': 'pulse 2s ease-in-out infinite',
                    }
                }
            }
        }
    </script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0a0a0a;
            color: #ffffff;
            padding: 20px;
        }

        .pomodoro-container {
            max-width: 400px;
            margin: 0 auto;
        }

        .pomodoro-card {
            background: #1a1a1a;
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s ease;
        }

        .pomodoro-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 255, 0, 0.1);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .card-title {
            font-size: 18px;
            font-weight: bold;
            color: #ffff00;
        }

        .session-dots {
            display: flex;
            gap: 6px;
        }

        .session-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #333;
            transition: all 0.3s ease;
        }

        .session-dot.completed {
            background: #ffff00;
            box-shadow: 0 0 8px rgba(255, 255, 0, 0.4);
        }

        .session-dot.current {
            background: #fff;
            animation: currentPulse 2s ease-in-out infinite;
        }

        @keyframes currentPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        /* Compact Timer */
        .timer-section {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 20px;
        }

        .timer-display {
            flex: 1;
            text-align: center;
        }

        .timer-time {
            font-size: 36px;
            font-weight: bold;
            color: #ffffff;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
            margin-bottom: 4px;
        }

        .timer-phase {
            font-size: 12px;
            color: #ffff00;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .timer-progress {
            width: 100px;
            height: 100px;
            position: relative;
            flex-shrink: 0;
        }

        .progress-circle {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: conic-gradient(var(--progress-color, #ffff00) var(--progress, 0deg), #333 var(--progress, 0deg));
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            transition: all 0.3s ease;
        }

        .progress-circle::before {
            content: '';
            position: absolute;
            top: 8px;
            left: 8px;
            right: 8px;
            bottom: 8px;
            border-radius: 50%;
            background: #1a1a1a;
        }

        .progress-percent {
            position: relative;
            z-index: 2;
            font-size: 14px;
            font-weight: bold;
            color: #fff;
        }

        /* Controls Row */
        .controls-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .main-controls {
            display: flex;
            gap: 8px;
        }

        .control-btn {
            width: 40px;
            height: 40px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .play-btn {
            background: #ffff00;
            color: #000;
        }

        .pause-btn {
            background: #ff6b6b;
            color: #fff;
        }

        .reset-btn, .skip-btn {
            background: #333;
            color: #fff;
        }

        .control-btn:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }

        /* Compact Settings */
        .settings-toggle {
            background: #333;
            border: none;
            color: #ffff00;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .settings-toggle:hover {
            background: #444;
        }

        .settings-panel {
            display: none;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 16px;
            padding: 16px;
            background: #0f0f0f;
            border-radius: 8px;
        }

        .settings-panel.open {
            display: grid;
        }

        .setting-group {
            text-align: center;
        }

        .setting-label {
            font-size: 10px;
            color: #666;
            margin-bottom: 4px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .setting-input {
            width: 100%;
            background: #333;
            border: 1px solid #444;
            color: #fff;
            border-radius: 4px;
            padding: 6px 8px;
            font-size: 12px;
            text-align: center;
        }

        .setting-input:focus {
            outline: none;
            border-color: #ffff00;
        }

        .setting-input.readonly {
            background: #222;
            border-color: #555;
            color: #ffff00;
            font-weight: bold;
        }

        /* Compact Stats */
        .stats-row {
            display: flex;
            justify-content: space-between;
            padding-top: 16px;
            border-top: 1px solid #333;
        }

        .stat {
            text-align: center;
            flex: 1;
        }

        .stat-value {
            font-size: 18px;
            font-weight: bold;
            color: #ffff00;
            margin-bottom: 2px;
        }

        .stat-label {
            font-size: 10px;
            color: #666;
            letter-spacing: 0.5px;
        }

        /* Control Icons */
        .icon-play::before {
            content: '';
            width: 0;
            height: 0;
            border-left: 12px solid currentColor;
            border-top: 8px solid transparent;
            border-bottom: 8px solid transparent;
            margin-left: 2px;
        }

        .icon-pause::before {
            content: '';
            width: 4px;
            height: 16px;
            background: currentColor;
            box-shadow: 6px 0 0 currentColor;
        }

        .icon-reset::before {
            content: '';
            width: 12px;
            height: 12px;
            border: 2px solid currentColor;
            border-radius: 50%;
            border-top-color: transparent;
        }

        .icon-skip::before {
            content: '';
            width: 0;
            height: 0;
            border-left: 10px solid currentColor;
            border-top: 6px solid transparent;
            border-bottom: 6px solid transparent;
        }

        .icon-skip::after {
            content: '';
            position: absolute;
            right: 12px;
            width: 2px;
            height: 12px;
            background: currentColor;
        }

        .icon-settings::before {
            content: '';
            width: 8px;
            height: 8px;
            border: 2px solid currentColor;
            border-radius: 50%;
        }

        .icon-settings::after {
            content: '';
            position: absolute;
            width: 12px;
            height: 12px;
            border: 1px solid currentColor;
            border-radius: 2px;
        }

        /* Phase Colors */
        .phase-work {
            --progress-color: #ffff00;
        }

        .phase-break {
            --progress-color: #4CAF50;
        }

        .phase-long-break {
            --progress-color: #2196F3;
        }

        /* Animations */
        .timer-running .progress-circle {
            animation: timerPulse 2s ease-in-out infinite;
        }

        @keyframes timerPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.02); }
        }

        .timer-finished .timer-section {
            animation: finishedFlash 0.5s ease-in-out 3;
        }

        @keyframes finishedFlash {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        /* Responsive */
        @media (max-width: 480px) {
            .timer-section {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }
            
            .timer-time {
                font-size: 32px;
            }
            
            .controls-row {
                flex-direction: column;
                gap: 12px;
            }
        }
    </style>
</head>
<body class="bg-dark-400 text-white p-5">
    <a href="study-tools.html" class="fixed top-5 left-5 py-2 px-4 bg-primary text-black rounded-full font-bold cursor-pointer no-underline z-10 hover:scale-105 transition-transform">← Back to Study Tools</a>

            .settings-panel.open {
                display: grid;
            }
                        <div class="progress-percent" id="progressPercent">0%</div>
                    </div>
                </div>
            </div>

            <div class="controls-row">
                <div class="main-controls">
                    <button class="control-btn play-btn" id="playBtn">
                        <div class="icon-play"></div>
                    </button>
                    <button class="control-btn pause-btn" id="pauseBtn" style="display: none;">
                        <div class="icon-pause"></div>
                    </button>
                    <button class="control-btn reset-btn" id="resetBtn">
                        <div class="icon-reset"></div>
                    </button>
                    <button class="control-btn skip-btn" id="skipBtn">
                        <div class="icon-skip"></div>
                    </button>
                </div>
                
                <button class="settings-toggle" id="settingsToggle">
                    <div class="icon-settings"></div>
                    Settings
                </button>
            </div>

            <div class="settings-panel" id="settingsPanel">
                <div class="setting-group">
                    <div class="setting-label">WORK TIME</div>
                    <select class="setting-input" id="workTime">
                        <option value="30">30 min</option>
                        <option value="45">45 min</option>
                        <option value="60">60 min</option>
                    </select>
                </div>
                <div class="setting-group">
                    <div class="setting-label">SESSIONS</div>
                    <select class="setting-input" id="sessionCount">
                        <option value="2">2 sessions</option>
                        <option value="3">3 sessions</option>
                        <option value="4" selected>4 sessions</option>
                        <option value="6">6 sessions</option>
                    </select>
                </div>
                <div class="setting-group">
                    <div class="setting-label">TOTAL TIME</div>
                    <div class="setting-input readonly" id="totalDuration">2h 30m</div>
                </div>
            </div>

            <div class="stats-row">
                <div class="stat">
                    <div class="stat-value" id="completedSessions">2</div>
                    <div class="stat-label">COMPLETED</div>
                </div>
                <div class="stat">
                    <div class="stat-value" id="totalTime">50m</div>
                    <div class="stat-label">TOTAL TIME</div>
                </div>
                <div class="stat">
                    <div class="stat-value" id="currentStreak">3</div>
                    <div class="stat-label">STREAK</div>
                </div>
            </div>
        </div>
    </div>

    <script src="js/script.js"></script>
    <script src="js/redirect.js"></script>
    <script src="js/components.js"></script>
<script>
        class CompactPomodoroTimer {
            constructor() {
                this.isRunning = false;
                this.currentPhase = 'work';
                this.sessionCount = 0;
                this.completedSessions = 2;
                this.totalMinutes = 50;
                this.currentStreak = 3;
                
                // Default settings
                this.workTime = 30; // Start with 30 min minimum
                this.totalSessions = 4;
                this.breakTime = 5; // Will be calculated based on work time
                this.longBreakTime = 15; // Will be calculated based on work time
                
                this.timeLeft = this.workTime * 60;
                this.totalTime = this.workTime * 60;
                
                this.timer = null;
                this.settingsOpen = false;
                
                this.calculateBreakTimes();
                this.initializeElements();
                this.bindEvents();
                this.updateDisplay();
                this.updateSessionDots();
                this.updateTotalDuration();
            }

            calculateBreakTimes() {
                // Auto-adjust break times based on work duration
                if (this.workTime === 30) {
                    this.breakTime = 5;
                    this.longBreakTime = 15;
                } else if (this.workTime === 45) {
                    this.breakTime = 10;
                    this.longBreakTime = 20;
                } else if (this.workTime === 60) {
                    this.breakTime = 10;
                    this.longBreakTime = 25;
                }
            }

            updateTotalDuration() {
                // Calculate total study session time
                const workMinutes = this.workTime * this.totalSessions;
                const shortBreaks = (this.totalSessions - 1) * this.breakTime;
                const longBreak = this.longBreakTime;
                const totalMinutes = workMinutes + shortBreaks + longBreak;
                
                const hours = Math.floor(totalMinutes / 60);
                const minutes = totalMinutes % 60;
                
                let durationText = '';
                if (hours > 0) {
                    durationText += `${hours}h `;
                }
                if (minutes > 0) {
                    durationText += `${minutes}m`;
                }
                
                document.getElementById('totalDuration').textContent = durationText.trim();
            }

            initializeElements() {
                this.timerDisplay = document.getElementById('timerDisplay');
                this.timerPhase = document.getElementById('timerPhase');
                this.progressCircle = document.getElementById('progressCircle');
                this.progressPercent = document.getElementById('progressPercent');
                this.playBtn = document.getElementById('playBtn');
                this.pauseBtn = document.getElementById('pauseBtn');
                this.resetBtn = document.getElementById('resetBtn');
                this.skipBtn = document.getElementById('skipBtn');
                this.settingsToggle = document.getElementById('settingsToggle');
                this.settingsPanel = document.getElementById('settingsPanel');
                
                this.workTimeSelect = document.getElementById('workTime');
                this.sessionCountSelect = document.getElementById('sessionCount');
                
                this.completedSessionsDisplay = document.getElementById('completedSessions');
                this.totalTimeDisplay = document.getElementById('totalTime');
                this.currentStreakDisplay = document.getElementById('currentStreak');
                
                // Set initial values
                this.workTimeSelect.value = this.workTime;
                this.sessionCountSelect.value = this.totalSessions;
            }

            bindEvents() {
                this.playBtn.addEventListener('click', () => this.start());
                this.pauseBtn.addEventListener('click', () => this.pause());
                this.resetBtn.addEventListener('click', () => this.reset());
                this.skipBtn.addEventListener('click', () => this.skip());
                this.settingsToggle.addEventListener('click', () => this.toggleSettings());
                
                this.workTimeSelect.addEventListener('change', () => this.updateSettings());
                this.sessionCountSelect.addEventListener('change', () => this.updateSettings());
            }

            toggleSettings() {
                this.settingsOpen = !this.settingsOpen;
                this.settingsPanel.classList.toggle('open', this.settingsOpen);
                this.settingsToggle.textContent = this.settingsOpen ? 'Close' : 'Settings';
            }

            start() {
                this.isRunning = true;
                this.playBtn.style.display = 'none';
                this.pauseBtn.style.display = 'flex';
                document.querySelector('.pomodoro-card').classList.add('timer-running');
                
                this.timer = setInterval(() => {
                    this.timeLeft--;
                    this.updateDisplay();
                    this.updateProgress();
                    
                    if (this.timeLeft <= 0) {
                        this.complete();
                    }
                }, 1000);
            }

            pause() {
                this.isRunning = false;
                this.playBtn.style.display = 'flex';
                this.pauseBtn.style.display = 'none';
                document.querySelector('.pomodoro-card').classList.remove('timer-running');
                
                clearInterval(this.timer);
            }

            reset() {
                this.pause();
                this.timeLeft = this.getCurrentPhaseDuration() * 60;
                this.totalTime = this.timeLeft;
                this.updateDisplay();
                this.updateProgress();
            }

            skip() {
                this.pause();
                this.complete();
            }

            complete() {
                this.pause();
                document.querySelector('.pomodoro-card').classList.add('timer-finished');
                
                // Brief notification
                this.playNotification();
                
                // Update stats
                if (this.currentPhase === 'work') {
                    this.completedSessions++;
                    this.sessionCount++;
                    this.totalMinutes += this.workTime;
                    this.updateStats();
                }
                
                // Auto-advance after brief delay
                setTimeout(() => {
                    document.querySelector('.pomodoro-card').classList.remove('timer-finished');
                    this.nextPhase();
                }, 2000);
            }

            nextPhase() {
                if (this.currentPhase === 'work') {
                    // Check if we've completed all sessions
                    if (this.sessionCount >= this.totalSessions) {
                        this.currentPhase = 'longBreak';
                        this.sessionCount = 0; // Reset for next cycle
                    } else {
                        this.currentPhase = 'break';
                    }
                } else {
                    this.currentPhase = 'work';
                }
                
                this.timeLeft = this.getCurrentPhaseDuration() * 60;
                this.totalTime = this.timeLeft;
                this.updateDisplay();
                this.updateProgress();
                this.updateSessionDots();
                this.updatePhaseStyle();
            }

            getCurrentPhaseDuration() {
                switch (this.currentPhase) {
                    case 'work': return this.workTime;
                    case 'break': return this.breakTime;
                    case 'longBreak': return this.longBreakTime;
                    default: return this.workTime;
                }
            }

            updateDisplay() {
                const minutes = Math.floor(this.timeLeft / 60);
                const seconds = this.timeLeft % 60;
                this.timerDisplay.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                
                const phaseText = {
                    'work': 'FOCUS TIME',
                    'break': 'SHORT BREAK',
                    'longBreak': 'LONG BREAK'
                };
                this.timerPhase.textContent = phaseText[this.currentPhase];
            }

            updateProgress() {
                const progress = ((this.totalTime - this.timeLeft) / this.totalTime) * 360;
                const percent = Math.round(((this.totalTime - this.timeLeft) / this.totalTime) * 100);
                
                this.progressCircle.style.setProperty('--progress', `${progress}deg`);
                this.progressPercent.textContent = `${percent}%`;
            }

            updatePhaseStyle() {
                this.progressCircle.className = `progress-circle phase-${this.currentPhase}`;
            }

            updateSessionDots() {
                const dots = document.querySelectorAll('.session-dot');
                
                // Hide/show dots based on total sessions
                dots.forEach((dot, index) => {
                    if (index >= this.totalSessions) {
                        dot.style.display = 'none';
                    } else {
                        dot.style.display = 'block';
                        dot.classList.remove('completed', 'current');
                        
                        if (index < this.sessionCount) {
                            dot.classList.add('completed');
                        } else if (index === this.sessionCount && this.currentPhase === 'work') {
                            dot.classList.add('current');
                        }
                    }
                });
            }

            updateStats() {
                this.completedSessionsDisplay.textContent = this.completedSessions;
                this.totalTimeDisplay.textContent = `${this.totalMinutes}m`;
                this.currentStreakDisplay.textContent = this.currentStreak;
            }

            updateSettings() {
                if (!this.isRunning) {
                    this.workTime = parseInt(this.workTimeSelect.value);
                    this.totalSessions = parseInt(this.sessionCountSelect.value);
                    
                    this.calculateBreakTimes();
                    this.updateTotalDuration();
                    
                    this.timeLeft = this.getCurrentPhaseDuration() * 60;
                    this.totalTime = this.timeLeft;
                    this.updateDisplay();
                    this.updateProgress();
                    this.updateSessionDots();
                }
            }

            playNotification() {
                // Quick audio beep
                try {
                    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                    const oscillator = audioContext.createOscillator();
                    const gainNode = audioContext.createGain();
                    
                    oscillator.connect(gainNode);
                    gainNode.connect(audioContext.destination);
                    
                    oscillator.frequency.setValueAtTime(800, audioContext.currentTime);
                    gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);
                    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.3);
                    
                    oscillator.start(audioContext.currentTime);
                    oscillator.stop(audioContext.currentTime + 0.3);
                } catch (e) {
                    // Fallback for browsers without audio context
                    console.log('Timer completed!');
                }
            }
        }

        // Initialize timer
        window.compactTimer = new CompactPomodoroTimer();

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.target.tagName === 'INPUT') return;
            
            if (e.code === 'Space') {
                e.preventDefault();
                if (window.compactTimer.isRunning) {
                    window.compactTimer.pause();
                } else {
                    window.compactTimer.start();
                }
            } else if (e.code === 'KeyR') {
                window.compactTimer.reset();
            } else if (e.code === 'KeyS') {
                window.compactTimer.skip();
            }
        });
    </script>
</body>
</html>
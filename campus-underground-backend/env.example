# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_underground
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration

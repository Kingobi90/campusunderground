#!/usr/bin/env python3
"""
Flask API server for Moodle integration with Campus Underground
"""

import os
import sys
import json
from flask import Flask, request, jsonify
from flask_cors import CORS
from dotenv import load_dotenv
import tempfile
import logging

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger('moodle_api_server')

# Add the parent directory to the path so we can import the client
sys.path.append(os.path.dirname(os.path.abspath(__file__)))
from moodle_client import MoodleAPIClient

# Load environment variables
load_dotenv()

# Initialize Flask app
app = Flask(__name__)
app.secret_key = os.getenv('FLASK_SECRET_KEY', 'campus-underground-secret-key')

# Enable CORS for all endpoints
CORS(app)

# Initialize Moodle client
moodle_client = None

def get_client():
    """Get or initialize the Moodle client"""
    global moodle_client
    if moodle_client is None:
        try:
            # Use mock data if the token is the placeholder or empty
            token = os.getenv('MOODLE_API_TOKEN', '')
            use_mock = token == 'your_moodle_api_token_here' or not token
            moodle_client = MoodleAPIClient(use_mock_data=use_mock)
            if use_mock:
                logger.info("Using mock data for Moodle API client")
            else:
                logger.info("Using real Moodle API with provided token")
        except Exception as e:
            logger.error(f"Failed to initialize Moodle client: {e}")
            return None
    return moodle_client

@app.route('/api/health', methods=['GET'])
def health_check():
    """Health check endpoint"""
    return jsonify({
        'status': 'OK',
        'message': 'Moodle API server is running'
    })

@app.route('/api/courses', methods=['GET'])
def get_courses():
    """Get user's Moodle courses"""
    try:
        user_id = request.headers.get('user-id')
        if not user_id:
            return jsonify({'error': 'User ID is required'}), 400
        
        client = get_client()
        if not client:
            return jsonify({'error': 'Failed to initialize Moodle client'}), 500
        
        courses = client.get_courses(int(user_id))
        return jsonify(courses)
    except Exception as e:
        logger.error(f"Error fetching courses: {e}")
        return jsonify({'error': str(e)}), 500

@app.route('/api/courses/<int:course_id>/contents', methods=['GET'])
def get_course_contents(course_id):
    """Get course contents"""
    try:
        client = get_client()
        if not client:
            return jsonify({'error': 'Failed to initialize Moodle client'}), 500
        
        contents = client.get_course_contents(course_id)
        return jsonify(contents)
    except Exception as e:
        logger.error(f"Error fetching course contents: {e}")
        return jsonify({'error': str(e)}), 500

@app.route('/api/courses/<int:course_id>/assignments', methods=['GET'])
def get_course_assignments(course_id):
    """Get course assignments"""
    try:
        user_id = request.headers.get('user-id')
        if not user_id:
            return jsonify({'error': 'User ID is required'}), 400
        
        client = get_client()
        if not client:
            return jsonify({'error': 'Failed to initialize Moodle client'}), 500
        
        assignments = client.get_assignments(course_id, int(user_id))
        return jsonify(assignments)
    except Exception as e:
        logger.error(f"Error fetching assignments: {e}")
        return jsonify({'error': str(e)}), 500

@app.route('/api/courses/<int:course_id>/grades', methods=['GET'])
def get_course_grades(course_id):
    """Get user grades for a course"""
    try:
        user_id = request.headers.get('user-id')
        if not user_id:
            return jsonify({'error': 'User ID is required'}), 400
        
        client = get_client()
        if not client:
            return jsonify({'error': 'Failed to initialize Moodle client'}), 500
        
        grades = client.get_user_grades(int(user_id), course_id)
        return jsonify(grades)
    except Exception as e:
        logger.error(f"Error fetching grades: {e}")
        return jsonify({'error': str(e)}), 500

@app.route('/api/download', methods=['POST'])
def download_file():
    """Download a file from Moodle"""
    try:
        data = request.json
        if not data or 'fileUrl' not in data:
            return jsonify({'error': 'File URL is required'}), 400
        
        file_url = data['fileUrl']
        
        client = get_client()
        if not client:
            return jsonify({'error': 'Failed to initialize Moodle client'}), 500
        
        # Download the file without saving it
        file_data = client.download_file(file_url)
        
        if isinstance(file_data, dict) and 'error' in file_data:
            return jsonify({'error': file_data['error']}), 500
        
        # Return file data as base64
        import base64
        if isinstance(file_data, dict) and 'content' in file_data:
            return jsonify({
                'content': base64.b64encode(file_data['content']).decode('utf-8'),
                'contentType': file_data['content_type'],
                'filename': file_data['filename']
            })
        else:
            return jsonify({'error': 'Failed to download file'}), 500
    except Exception as e:
        logger.error(f"Error downloading file: {e}")
        return jsonify({'error': str(e)}), 500

@app.route('/api/calendar-events', methods=['GET'])
def get_calendar_events():
    """Get calendar events"""
    try:
        events_from = request.args.get('from')
        events_to = request.args.get('to')
        
        client = get_client()
        if not client:
            return jsonify({'error': 'Failed to initialize Moodle client'}), 500
        
        events = client.get_calendar_events(events_from, events_to)
        return jsonify(events)
    except Exception as e:
        logger.error(f"Error fetching calendar events: {e}")
        return jsonify({'error': str(e)}), 500

# Analytics endpoints


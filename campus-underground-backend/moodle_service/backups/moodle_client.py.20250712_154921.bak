"""
Moodle API Client for Campus Underground
This module provides a client for interacting with Moodle's web services API.
"""

import requests
from typing import Dict, Any, List, Optional, Union
import os
import requests
import logging
import tempfile
import time
import random
from datetime import datetime, timedelta
import json
import dotenv

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger('moodle_client')

# Load environment variables
dotenv.load_dotenv()

class MoodleAPIClient:
    """Client for interacting with Moodle's Web Services API."""
    
    def __init__(self, use_mock_data=False):
        """Initialize the Moodle API client"""
        self.base_url = os.getenv('MOODLE_URL', 'https://moodle.concordia.ca')
        self.token = os.getenv('MOODLE_API_TOKEN', '')
        self.logger = logging.getLogger('moodle_client')
        self.use_mock_data = use_mock_data or self.token == 'your_moodle_api_token_here'
        
        if self.use_mock_data:
            self.logger.info("Using mock data for Moodle API client")
        else:
            self.logger.info(f"Moodle API client initialized with base URL: {self.base_url}")
        
        # Ensure the base URL ends with a slash
        if not self.base_url.endswith('/'):
            self.base_url += '/'
            
        # Web service endpoint
        self.ws_endpoint = os.path.join(self.base_url, "webservice/rest/server.php")
        
        # Default parameters for all requests
        self.default_params = {
            "wstoken": self.token,
            "moodlewsrestformat": "json"
        }
        
    def request(self, function, **kwargs):
        """Make a request to the Moodle API"""
        if self.use_mock_data:
            return self._get_mock_data(function, **kwargs)
        
        # Prepare the parameters
        params = {
            'wstoken': self.token,
            'moodlewsrestformat': 'json',
            'wsfunction': function,
            **kwargs
        }
        
        # Try multiple URL formats - prioritize the one that works in fetch_demo.py
        urls_to_try = [
            f"{self.base_url}/moodle/webservice/rest/server.php",  # This one works in fetch_demo.py
            f"{self.base_url}/webservice/rest/server.php"
        ]
        
        last_error = None
        for attempt, url in enumerate(urls_to_try, 1):
            try:
                self.logger.info(f"Attempt {attempt}: Making request to: {url}")
                response = requests.get(url, params=params)
                response.raise_for_status()
                return response.json()
            except requests.exceptions.RequestException as e:
                self.logger.error(f"Request failed: {e}")
                last_error = e
                if hasattr(e, 'response') and e.response is not None:
                    self.logger.error(f"Response content: {e.response.text}")
                
                if attempt < len(urls_to_try):
                    self.logger.info(f"Trying alternative URL format (attempt {attempt+1})...")
        
        self.logger.error("All URL formats failed")
        return None
            
    def _make_request(self, function, params=None):
        """Alias for request method to maintain compatibility"""
        return self.request(function, params)
            
